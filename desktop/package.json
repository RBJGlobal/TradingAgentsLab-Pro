{
  "name": "tradingagentslab-pro-desktop",
  "productName": "Trading Agents Lab Pro",
  "version": "1.0.0",
  "private": true,
  "description": "Trading Agents Lab Pro desktop — full multi-agent diligence on the real LangGraph engine (paid, proprietary)",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "tsc -b --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ui": "npm run build && playwright test --ui",
    "build:engine": "bash ../tools/build-engine.sh",
    "dist:dir": "npm run build && npm run build:engine && CSC_IDENTITY_AUTODISCOVERY=false electron-builder --mac --dir",
    "dist:mac": "npm run build && npm run build:engine && electron-builder --mac",
    "postinstall": "bash ../tools/patch-electron-info-plist.sh"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "happy-dom": "^20.10.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.4"
  }
}
