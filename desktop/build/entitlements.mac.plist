<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Electron's V8 and the bundled CPython both need JIT / writable-executable
       memory under the hardened runtime. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- The PyInstaller-frozen engine loads its own bundled dylibs; without this
       the hardened runtime rejects libraries not signed by the app's identity. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- PyInstaller's bootloader sets DYLD_* env vars to locate its bundle. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <!-- Engine binds 127.0.0.1 (server) and calls data/LLM providers (client). -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>
</dict>
</plist>
